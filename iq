#!/usr/bin/env bash
# iq — launch Claude Code in the one InferenceIQ mode.
#
# Every prompt is auto-optimized and every reply is auto-shortened by the proxy
# (Claude answers the optimized version directly — no confirmation), and the
# savings are collected live on the dashboard at http://3.96.147.26:8088.
#
# Usage:  ./iq            # interactive Claude Code, optimized
#         ./iq -p "..."   # one-shot, optimized
#
# This is SCOPED to this command — it does not change any global config. If the
# proxy is ever down, just run plain `claude` and you're back to normal.
DIR="/Users/svuillaume/caching_project/inferenceiq"

# Make sure the proxy (:8082) and dashboard (:8088) are up so nothing breaks.
( cd "$DIR" && docker compose up -d >/dev/null 2>&1 ) \
  || { echo "iq: could not start the proxy (is Docker running?)" >&2; exit 1; }

# Resolve the REAL claude binary (so an `alias claude=iq` can't recurse into this).
CLAUDE_BIN="${CLAUDE_BIN:-/Users/svuillaume/.local/bin/claude}"
[ -x "$CLAUDE_BIN" ] || CLAUDE_BIN="$(command -v claude)"

echo "iq · optimizing through localhost:8082 · savings → http://3.96.147.26:8088" >&2
exec env ANTHROPIC_BASE_URL="http://localhost:8082" "$CLAUDE_BIN" "$@"
