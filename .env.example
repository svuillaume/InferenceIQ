# InferenceIQ — single environment file (all variables).
#
#   cp .env.example .env   then edit. `docker compose` auto-loads `.env` and substitutes the
#   ${VARS} in compose.yml, so this one file configures the whole stack (proxy + dashboard).
#
# Leave anything you don't care about commented — every var has a sane default in code/compose.
# Vars marked [host] are read by the CLI/hook on the machine that runs them, NOT by the containers
# (set those in your shell or ~/.inferenceiq.json), so they live here for reference.

# ── Dashboard / reporting ─────────────────────────────────────────────────────
# SINGLE source of truth for the dashboard location. Drives BOTH where the proxy
# reports (INFERENCEIQ_DASHBOARD) and where /dashboard redirects a browser
# (DASHBOARD_PUBLIC_URL). Set this one var to point the whole stack at a collector.
# (The CLI uses ~/.inferenceiq.json instead.)
DASHBOARD_URL=http://3.96.147.26:8088
# Override these two ONLY when they must differ — e.g. local Docker, where the
# proxy reports to host.docker.internal:8088 but the browser opens localhost:8088:
#   INFERENCEIQ_DASHBOARD=http://host.docker.internal:8088
#   DASHBOARD_PUBLIC_URL=http://localhost:8088
# Shared secret for the collector's WRITE endpoints (/api/record, /api/reset, /api/tz).
# Empty = OPEN. SET THIS before exposing the dashboard publicly; every reporter must match it.
IQ_TOKEN=
# Privacy: 0 = report counts + host only (recommended); 1 = also send prompt before/after text.
IQ_REPORT_TEXT=0
# Pin the dashboard's feed timezone (e.g. America/Toronto). Empty = auto-detect via public IP.
IQ_TZ=

# ── Proxy: core (intercept.py) ────────────────────────────────────────────────
# 0 = pure passthrough (no input optimization).
OPTIMIZE_ENABLED=1
# Savings counter mode: estimate (instant chars/4) | exact (count_tokens in background; needs key).
COUNT_MODE=estimate
# Upstream API base — override for tests/self-host only.
ANTHROPIC_UPSTREAM=https://api.anthropic.com

# ── Proxy: output trimming (the big lever) ────────────────────────────────────
# 1 = append a brevity directive to the last user turn → shorter (cheaper) replies.
CONCISE=1
# Override the brevity directive text (empty = code default).
CONCISE_NOTE=

# ── Proxy: model routing ──────────────────────────────────────────────────────
# on (default, override the model) | advise (report the pick only) | off.
# Agentic requests (tools / tool_result) are NEVER routed, so Claude Code is unaffected.
ROUTE_MODELS=on

# ── Proxy: semantic response cache (semcache.py) ──────────────────────────────
CACHE_ENABLED=1
CACHE_INDEX=numpy                       # numpy (default) | hnsw | faiss
CACHE_HIT=0.92                          # cosine ≥ this serves a cached answer
CACHE_SOFT=0.88                         # [soft,hit) = near-miss (logged, not served)
CACHE_DEDUP=0.97                        # ≥ this on store → merge instead of insert
CACHE_MAX_MB=50                         # store budget (embeddings + responses)
CACHE_PER_MODEL=0                       # 1 = namespace the cache per requested model
CACHE_MODEL=BAAI/bge-small-en-v1.5      # local ONNX embedding model (~90MB)
CACHE_PERSIST_PATH=/cache/store.json    # persist across restarts (empty = in-memory only)

# ── Dashboard installer (dashboard/install.sh, dashboard/run.sh) — [host] ─────
# PORT=8088
# NAME=iq-dashboard
# IMAGE=iq-dashboard

# ── CLI (run on YOUR machine — [host], not the containers) ────────────────────
# Needed only for EXACT token counts; optimize falls back to estimates.
# ANTHROPIC_API_KEY=sk-ant-...
# Override the config-file path the CLI reads (default ~/.inferenceiq.json).
# IQ_CONFIG=
# Disable ANSI colors in CLI output.
# NO_COLOR=1
